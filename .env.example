# ==========================================
# Hash Resume - Environment Variables
# ==========================================

# --- AI & External Services ---
# GEMINI_API_KEY: Required for Gemini AI API calls (Resume Generation, ATS Scoring).
# SECURITY NOTE: In production (AI Studio/Cloud Run), this is injected securely via secrets.
# DO NOT expose this key to the client-side directly. It should only be used in server-side code or securely proxied.
GEMINI_API_KEY="your_gemini_api_key_here"

# --- Application URLs ---
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# --- Google Sheets API ---
# GOOGLE_SHEETS_API_KEY: API key for Google Sheets API
GOOGLE_SHEETS_API_KEY="your_google_sheets_api_key_here"
# GOOGLE_SHEET_ID: The ID of the Google Sheet containing job data
GOOGLE_SHEET_ID="your_google_sheet_id_here"

# --- Google Apps Script ---
GOOGLE_APPS_SCRIPT_PAYMENT_URL="https://script.google.com/macros/s/AKfycbxEwZAiv_ja3Tlpno6HWp-OL1ur2WPkRq_9V4BTqquWsfX1gAEacB9vu-iRowF9FxDI-A/exec"
GOOGLE_APPS_SCRIPT_FEEDBACK_URL="your_feedback_script_url_here"
GOOGLE_APPS_SCRIPT_HASHHUNT_URL="your_hashhunt_script_url_here"

# --- Analytics ---
# VITE_GA_MEASUREMENT_ID: Google Analytics Measurement ID (Safe to expose to frontend)
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# --- Database / Storage ---
# DATABASE_URL: Connection string for the database (if applicable)
DATABASE_URL="file:./dev.db"
