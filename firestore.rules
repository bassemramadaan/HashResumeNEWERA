rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: resumes
    // Document ID: {resumeId}
    // Fields:
    //   - userId: string (required)
    //   - personalInfo: map (optional)
    //   - experience: list (optional)
    //   - education: list (optional)
    //   - skills: list (optional)
    //   - projects: list (optional)
    //   - certifications: list (optional)
    //   - customSections: list (optional)
    //   - settings: map (optional)
    //   - jobDescription: string (optional)
    //   - isPremium: bool (optional)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.email is string &&
             data.createdAt is timestamp;
    }

    function isValidResume(data) {
      return data.keys().hasAll(['userId', 'updatedAt']) &&
             data.userId is string &&
             data.updatedAt is timestamp &&
             data.userId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /resumes/{resumeId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidResume(request.resource.data);
      allow update: if isDocOwner() && isValidResume(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
